repeat task.wait() until game:IsLoaded()

local Settings = {
    MaxPlayersToLeave = 15, 
    MaxTimeInMinutes = 15,   
    TargetMaxPlayers = 10,   
    AbsoluteMaxLimit = 20,
    WebhookURL = "",
    
    -- 🛑 ตั้งค่าระบบแอดมิน
    HopOnAdmin = true, 
    AdminIDs = {
        12345678, -- ใส่ UserID ของแอดมินที่รู้ตัวแน่นอนตรงนี้ได้เลย
        87654321
    },
    
    -- 🏢 ตั้งค่าระบบกลุ่ม (Group)
    GroupID = 33720745, -- ไอดีกลุ่ม Cinnamon Go!
    AdminMinRank = 200 -- ระดับยศที่ถือว่าเป็นแอดมิน (255 คือเจ้าของกลุ่ม, 200+ มักจะเป็นแอดมิน/Dev)
}

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local StartTime = tick()

local function httpRequest(url, method, body)
    local requestFunc = syn and syn.request or http_request or request or http and http.request
    if requestFunc then
        return requestFunc({Url = url, Method = method or "GET", Headers = {["Content-Type"] = "application/json"}, Body = body})
    else
        local success, result = pcall(function()
            return (method == "POST") and HttpService:PostAsync(url, body) or game:HttpGet(url)
        end)
        return {Success = success, Body = result}
    end
end

-- ==========================================
-- 🛑 ฟังก์ชันเช็คแอดมิน (อัปเกรดรองรับ Group)
-- ==========================================
local function IsAdmin(player)
    -- 1. เช็คจาก ID ที่ระบุไว้เจาะจง
    if table.find(Settings.AdminIDs, player.UserId) then return true end
    
    -- 2. เช็คจากคนสร้างเกม (กรณีไม่ใช่เกมของกลุ่ม)
    if game.CreatorType == Enum.CreatorType.User and player.UserId == game.CreatorId then return true end
    
    -- 3. เช็คจาก Group Rank (ถ้ามียศสูงกว่าที่ตั้งไว้ ให้ถือว่าเป็นแอดมิน)
    if Settings.GroupID > 0 then
        local success, rank = pcall(function()
            return player:GetRankInGroup(Settings.GroupID)
        end)
        if success and rank >= Settings.AdminMinRank then
            return true
        end
    end
    
    return false
end

local function SendToDiscord(status, oldPlayers, newPlayers, targetJobId, isCache, hopReason)
    if Settings.WebhookURL == "" then return end
    
    local sourceText = isCache and "📦 (จาก Cache ในเครื่อง)" or "🌐 (จาก Roblox API)"
    
    -- 🎨 ระบบกำหนดสี (Priority: Admin > Cache > API)
    local embedColor = 45055 -- เริ่มต้น: สีเขียวปกติ (API)
    
    if isCache then 
        embedColor = 5763719 -- สีเขียวเข้ม (Cache)
    end
    
    if hopReason == "Admin" then 
        embedColor = 16711680 -- สีแดง (หนีแอดมิน) ทับทุกสี!
        status = "🚨 แอดมินเข้าเกม! ย้ายฉุกเฉิน!"
    end

    local data = {
        ["content"] = "**[Bot Notification]** " .. sourceText,
        ["embeds"] = {{
            ["color"] = embedColor,
            ["fields"] = {
                {["name"] = "🗺️ Map & PlaceID", ["value"] = game.Name .. " (ID: " .. tostring(game.PlaceId) .. ")", ["inline"] = false},
                {["name"] = "🤖 Account", ["value"] = Players.LocalPlayer.Name, ["inline"] = true},
                {["name"] = "🚀 Status", ["value"] = status, ["inline"] = true},
                {["name"] = "👥 Players", ["value"] = tostring(oldPlayers) .. " > " .. tostring(newPlayers), ["inline"] = true},
                {["name"] = "🔗 JobId", ["value"] = "```" .. tostring(targetJobId) .. "```", ["inline"] = false},
            }
        }}
    }
    httpRequest(Settings.WebhookURL, "POST", HttpService:JSONEncode(data))
end

local function ServerHop(hopReason)
    local CurrentPlayersCount = #Players:GetPlayers()
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    -- 📁 สร้างชื่อไฟล์ Cache แยกตาม PlaceID
    local CacheFileName = tostring(game.PlaceId) .. "_ServerList.json"
    
    local response = httpRequest(url)
    local serverData = nil
    local usingCache = false

    if response.Success and response.Body and not response.Body:find("Error") then
        local decoded = HttpService:JSONDecode(response.Body)
        if decoded and decoded.data and #decoded.data > 0 then
            serverData = decoded.data
            pcall(function()
                writefile(CacheFileName, HttpService:JSONEncode(serverData))
            end)
        end
    end

    if not serverData then
        if isfile(CacheFileName) then
            serverData = HttpService:JSONDecode(readfile(CacheFileName))
            usingCache = true
        end
    end

    if serverData then
        for currentLimit = Settings.TargetMaxPlayers, Settings.AbsoluteMaxLimit do
            local ValidServers = {}
            for _, server in ipairs(serverData) do
                if server.id ~= game.JobId and server.playing <= currentLimit then
                    table.insert(ValidServers, server)
                end
            end

            if #ValidServers > 0 then
                local RandomServer = ValidServers[math.random(1, #ValidServers)]
                SendToDiscord("ย้ายเซิร์ฟเวอร์สำเร็จ!", CurrentPlayersCount, RandomServer.playing, RandomServer.id, usingCache, hopReason)
                task.wait(1)
                game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, RandomServer.id, Players.LocalPlayer)
                return
            end
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    if Settings.HopOnAdmin and IsAdmin(player) then
        print("🚨 ตรวจพบแอดมิน: " .. player.Name .. " กำลังทำการหลบหนี!")
        ServerHop("Admin") 
    end
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= Players.LocalPlayer and Settings.HopOnAdmin and IsAdmin(player) then
        print("🚨 เซิร์ฟนี้มีแอดมินอยู่แล้ว: " .. player.Name .. " กำลังทำการหลบหนี!")
        ServerHop("Admin")
        break
    end
end

task.spawn(function()
    while task.wait(5) do
        local CurrentPlayers = #Players:GetPlayers()
        local TimeElapsed = (tick() - StartTime) / 60

        if CurrentPlayers > Settings.MaxPlayersToLeave or TimeElapsed >= Settings.MaxTimeInMinutes then
            ServerHop("Normal")
            task.wait(10)
        end
    end
end)

print("✅")
